# ============================================================
# DonorMatch — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Django
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=*
BASE_URL=https://yourdomain.com

# Database (PostgreSQL)
POSTGRES_DB=donormatch
POSTGRES_USER=donormatch
POSTGRES_PASSWORD=strong-db-password-here

# Redis
REDIS_URL=redis://redis:6379/0

# N8N Workflow Integration
N8N_WEBHOOK_URL=https://donormatch.app.n8n.cloud/webhook-test/emergency-blood-request
N8N_API_KEY=your-n8n-api-key

# ML Engine Settings
ML_CONFIDENCE_THRESHOLD=0.75
ML_AUTONOMOUS_MODE_THRESHOLD=50
